# Spotify API Credentials (get from https://developer.spotify.com/dashboard)
# End users NEVER need to touch these — only developers set them up once.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Security — generate with: openssl rand -base64 32
SESSION_SECRET=this_must_be_at_least_32_characters_long_for_iron_session

# Vercel KV / Redis (Upstash) — leave empty for local dev
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Database
DATABASE_URL="file:./dev.db"

# Site config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
